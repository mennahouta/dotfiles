      "import { IsString, IsEmail, IsOptional, MinLength, MaxLength } from 'class-validator';",
      "",
      "export class Create${1:Entity}Dto {",
      "  ${2:properties}",
      "}",
      "",
      "export class Update${1:Entity}Dto extends Create${1:Entity}Dto {",
      "  ${3:optional_properties}",
      "}"
    ]
  },
