{
  "NestJS Module": {
    "prefix": "module",
    "description": "Create a NestJS module",
    "body": [
      "import { Module } from '@nestjs/common';",
      "import { ${1:Service}Service } from './${2:service}.service';",
      "import { ${3:Controller}Controller } from './${4:controller}.controller';",
      "",
      "@Module({",
      "  imports: [],",
      "  controllers: [${3:Controller}Controller],",
      "  providers: [${1:Service}Service],",
      "  exports: [${1:Service}Service],",
      "})",
      "export class ${5:Module}Module {}"
    ]
  },
  "NestJS Controller": {
    "prefix": "controller",
    "description": "Create a NestJS controller",
    "body": [
      "import { Controller, Get, Post, Put, Delete, Body, Param, Query } from '@nestjs/common';",
      "import { ${1:Service}Service } from './${2:service}.service';",
      "import { Create${3:Entity}Dto } from './dto/create-${4:entity}.dto';",
      "import { Update${3:Entity}Dto } from './dto/update-${4:entity}.dto';",
      "",
      "@Controller('${5:route}')",
      "export class ${6:Controller}Controller {",
      "  constructor(private readonly ${1:Service}Service: ${1:Service}Service) {}",
      "",
      "  @Get()",
      "  findAll(@Query() query: any) {",
      "    return this.${1:Service}Service.findAll(query);",
      "  }",
      "",
      "  @Get(':id')",
      "  findOne(@Param('id') id: string) {",
      "    return this.${1:Service}Service.findOne(id);",
      "  }",
      "",
      "  @Post()",
      "  create(@Body() create${3:Entity}Dto: Create${3:Entity}Dto) {",
      "    return this.${1:Service}Service.create(create${3:Entity}Dto);",
      "  }",
      "",
      "  @Put(':id')",
      "  update(@Param('id') id: string, @Body() update${3:Entity}Dto: Update${3:Entity}Dto) {",
      "    return this.${1:Service}Service.update(id, update${3:Entity}Dto);",
      "  }",
      "",
      "  @Delete(':id')",
      "  remove(@Param('id') id: string) {",
      "    return this.${1:Service}Service.remove(id);",
      "  }",
      "}"
    ]
  },
  "NestJS Service": {
    "prefix": "service",
    "description": "Create a NestJS service",
    "body": [
      "import { Injectable, NotFoundException } from '@nestjs/common';",
      "import { Repository } from '@litecore/common';",
      "import { ${1:Entity} } from './entities/${2:entity}.entity';",
      "import { Create${3:Entity}Dto } from './dto/create-${4:entity}.dto';",
      "import { Update${3:Entity}Dto } from './dto/update-${4:entity}.dto';",
      "",
      "@Injectable()",
      "export class ${5:Service}Service {",
      "  constructor(",
      "    @InjectRepository(${1:Entity})",
      "    private readonly ${6:repository}: Repository<${1:Entity}, string>,",
      "  ) {}",
      "",
      "  async create(create${3:Entity}Dto: Create${3:Entity}Dto): Promise<${1:Entity}> {",
      "    const ${7:entity} = this.${6:repository}.create(create${3:Entity}Dto);",
      "    return this.${6:repository}.save(${7:entity});",
      "  }",
      "",
      "  async findAll(query: any = {}): Promise<${1:Entity}[]> {",
      "    return this.${6:repository}.findAll(query);",
      "  }",
      "",
      "  async findOne(id: string): Promise<${1:Entity}> {",
      "    const ${8:entity} = await this.${6:repository}.findById(id);",
      "    if (!${8:entity}) {",
      "      throw new NotFoundException('${1:Entity} not found');",
      "    }",
      "    return ${8:entity};",
      "  }",
      "",
      "  async update(id: string, update${3:Entity}Dto: Update${3:Entity}Dto): Promise<${1:Entity}> {",
      "    await this.${6:repository}.update(id, update${3:Entity}Dto);",
      "    return this.findOne(id);",
      "  }",
      "",
      "  async remove(id: string): Promise<void> {",
      "    await this.${6:repository}.delete(id);",
      "  }",
      "}"
    ]
  },
  "NestJS Entity": {
    "prefix": "entity",
    "description": "Create a NestJS entity",
    "body": [
      "import { PrimaryGeneratedColumn, Column, CreateDateColumn, UpdateDateColumn } from 'typeorm';",
      "",
      "export class ${1:Entity} {",
      "  @PrimaryGeneratedColumn('uuid')",
      "  id: string;",
      "",
      "  ${2:columns}",
      "",
      "  @CreateDateColumn({ name: 'created_at' })",
      "  createdAt: Date;",
      "",
      "  @UpdateDateColumn({ name: 'updated_at' })",
      "  updatedAt: Date;",
      "}"
    ]
  },
